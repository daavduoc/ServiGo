# Copia este archivo como application.properties y completa tus valores.

spring.datasource.url=jdbc:mysql://HOST:PUERTO/BASE?allowPublicKeyRetrieval=true&useSSL=false
spring.datasource.username=root
spring.datasource.password=TU_PASSWORD_DB

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

jwt.secret=TU_SECRETO_JWT_LARGO
jwt.expiration=86400000

# Gmail: cuenta con verificación en 2 pasos + contraseña de aplicación (16 letras, sin espacios)
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=tu-cuenta@gmail.com
spring.mail.password=xxxxxxxxxxxxxxxx
spring.mail.from=tu-cuenta@gmail.com
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
